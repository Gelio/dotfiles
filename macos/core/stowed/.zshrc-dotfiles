path+=("$HOME/.cargo/bin/")
path+=("$(go env GOPATH)/bin/")
export path

# Set locale (otherwise, stow shows some warnings)
# https://stackoverflow.com/a/7413863
export LC_CTYPE=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# Load completions from ~/.zfunc
# https://github.com/python-poetry/poetry/issues/7974#issue-1718266255
fpath+=~/.zfunc
# Load completion
# https://stackoverflow.com/a/58517668
autoload -Uz compinit && compinit

# Use pre-nvim-EDITOR keybinds in the shell
# https://stackoverflow.com/a/43087047
bindkey -e

# Alt+Arrow for moving forward/back
# https://stackoverflow.com/a/12403798
bindkey "^[[1;3C" vi-forward-word
bindkey "^[[1;3D" vi-backward-word

# Ctrl+Arrow for moving forward/back
# https://unix.stackexchange.com/a/140499
bindkey "^[[1;5C" vi-forward-word
bindkey "^[[1;5D" vi-backward-word

# Ctrl-X Ctrl-E to edit the current command line in $EDITOR
# https://unix.stackexchange.com/a/34251
# Same as in Bash
autoload -z edit-command-line
zle -N edit-command-line
bindkey "^X^E" edit-command-line

# Alt+Delete to delete word stopping at non-word characters
# https://unix.stackexchange.com/a/319854
backward-kill-dir () {
    local WORDCHARS=""
    zle backward-kill-word
    zle -f kill
}
zle -N backward-kill-dir
bindkey '^[^?' backward-kill-dir

# Completions
# Show hidden files in completions
# https://unix.stackexchange.com/a/366137
setopt globdots
# Turn off cycling completions
# https://superuser.com/a/1753574
setopt noautomenu
# Enable colors in completions
zstyle ':completion:*:*' list-colors ''
zstyle ':completion:*:directories' list-colors '=*=0;34;40'
zstyle ':completion:*:local-directories' list-colors '=*=0;34;40'

# Fix access to imagemagick for image.nvim (Neovim)
# lhttps://github.com/3rd/image.nvim
export DYLD_FALLBACK_LIBRARY_PATH="$(brew --prefix)/lib:$DYLD_FALLBACK_LIBRARY_PATH"

# Fixed-path ssh-agent so git SSH commit-signing works inside Claude Code's
# sandbox. launchd's default agent socket lives at a per-boot randomized path
# (/private/var/run/com.apple.launchd.*/Listeners) that the sandbox can't
# allowlist by glob; a stable path can be. --apple-use-keychain pulls the
# passphrase from Keychain so this stays non-interactive.
export SSH_AUTH_SOCK="$HOME/.ssh/agent.sock"
# `ssh-add -l` exit codes drive the two cases; 0 (agent up, key loaded) = no-op.
ssh-add -l >/dev/null 2>&1
case $? in
  # 2 = can't reach any agent (first shell after boot; stale socket). Start a
  # fresh agent at the fixed path, then load the key.
  2) rm -f "$SSH_AUTH_SOCK"; ssh-agent -a "$SSH_AUTH_SOCK" >/dev/null
     ssh-add --apple-use-keychain "$HOME/.ssh/id_ed25519" </dev/null 2>/dev/null ;;
  # 1 = agent running but holds no identities (agent outlived Keychain unlock,
  # or key never added). Just load the key; don't spawn a duplicate agent.
  1) ssh-add --apple-use-keychain "$HOME/.ssh/id_ed25519" </dev/null 2>/dev/null ;;
esac

for file in ~/.zshrc.d/*(-.); do
  source "$file"
done
