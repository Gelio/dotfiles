{
  "name": "worktrees",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "worktrees": "bin/worktrees.ts"
  },
  "exports": {
    ".": "./src/types.ts"
  },
  "scripts": {
    "test": "node --test 'test/*.test.ts'",
    "test:coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-coverage-exclude='test/**' --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info 'test/*.test.ts'",
    "test:update-snapshots": "node --test --test-update-snapshots 'test/*.test.ts'",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt --write src bin test",
    "format:check": "oxfmt --check src bin test",
    "knip": "knip"
  },
  "dependencies": {
    "zx": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "knip": "^6.16.1",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "typescript": "^5.8.0"
  }
}
